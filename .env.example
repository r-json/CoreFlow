# CoreFlow Environment Variables
# Stellar Freighter Integration Guide - Section 3

# ========== NETWORK CONFIGURATION ==========
# Network to use: testnet or public
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# ========== STELLAR READ ADDRESS (Section 3 - Critical) ==========
# This is the public key used for read-only contract simulations
# It does NOT require signing authority
# Used by CoreFlowClient.simulateManagerApprove() and CoreFlowClient.simulateFinanceApprove()
# IMPORTANT: This must be a valid Stellar public key on the configured network
NEXT_PUBLIC_STELLAR_READ_ADDRESS=

# ========== CONTRACT CONFIGURATION ==========
# The deployed CoreFlow contract address on Testnet or Mainnet
# Example: CAU3FQTWCAFJF4XFVRXSEPWRPBCVHDSRBSCPTM75HJFDZD5XQQQY47A4
# Update this after deploying the contract
NEXT_PUBLIC_STELLAR_CONTRACT_ID=

# ========== WALLET CONFIGURATION ==========
# Freighter wallet timeout in milliseconds
NEXT_PUBLIC_FREIGHTER_TIMEOUT=5000

# ========== RPC ENDPOINTS ==========
# These are determined by NEXT_PUBLIC_STELLAR_NETWORK
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
# (Automatically selected based on NEXT_PUBLIC_STELLAR_NETWORK)

# ========== API KEYS ==========
# If using additional third-party services:
# NEXT_PUBLIC_SOME_API_KEY=
